<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="8dp"
    android:clickable="true"
    android:focusable="true"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp"
    app:strokeWidth="1.5dp"
    app:strokeColor="@color/card_stroke_light"
    app:cardBackgroundColor="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- User Info Row (Header) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <!-- Circular User Avatar via FrameLayout -->
            <FrameLayout
                android:id="@+id/layout_social_avatar_container"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_marginEnd="10dp"
                android:background="@drawable/bg_badge_rounded"
                android:backgroundTint="@color/color_container">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_social_avatar_photo"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:cardCornerRadius="19dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    android:visibility="visible">
                    
                    <ImageView
                        android:id="@+id/img_social_avatar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:contentDescription="User Avatar" />
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:id="@+id/text_social_avatar_emoji"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:textSize="20sp"
                    android:text="👤"
                    android:visibility="gone" />
            </FrameLayout>

            <!-- Username & Time metadata -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/text_social_username"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="\@kaizen_warrior"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textStyle="bold"
                    android:textSize="13sp"/>

                <TextView
                    android:id="@+id/text_social_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2 jam yang lalu"
                    android:textColor="@color/neutral_gray"
                    android:textSize="11sp"/>
            </LinearLayout>

            <!-- Premium Badge/Category -->
            <TextView
                android:id="@+id/text_social_tag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PRODUKTIVITAS"
                android:textColor="?attr/colorPrimary"
                android:textSize="9sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:background="@drawable/bg_badge_rounded"
                android:backgroundTint="@color/color_container"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp" />
        </LinearLayout>

        <!-- Post Title/Body Description -->
        <TextView
            android:id="@+id/text_social_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Konsistensi adalah Kunci Sukses"
            android:textColor="@color/on_color_container"
            android:textStyle="bold"
            android:textSize="15sp"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/text_social_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hari ke-15 melakukan meditasi pagi tanpa putus. Merasa jauh lebih fokus dan tenang menghadapi tumpukan pekerjaan harian! 🧘✨"
            android:textColor="@color/neutral_gray"
            android:textSize="13sp"
            android:lineSpacingMultiplier="1.1"
            android:layout_marginBottom="12dp" />

        <!-- Bento Post Main Photo via Nested CardView to clip the image -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_social_image"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            android:layout_marginBottom="12dp">

            <ImageView
                android:id="@+id/img_social_post"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@android:drawable/alert_dark_frame"
                android:contentDescription="Post Image" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Interaction Bar (Action buttons) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="4dp">

            <!-- Like Interaction with Animation trigger -->
            <LinearLayout
                android:id="@+id/layout_social_like"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:background="?android:attr/selectableItemBackground"
                android:padding="6dp"
                android:layout_marginEnd="16dp">

                <ImageView
                    android:id="@+id/img_social_like_icon"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@android:drawable/btn_star_big_off"
                    android:layout_marginEnd="4dp" />

                <TextView
                    android:id="@+id/text_social_likes_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="28"
                    android:textColor="@color/neutral_gray"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Share Interaction -->
            <LinearLayout
                android:id="@+id/layout_social_share"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:background="?android:attr/selectableItemBackground"
                android:padding="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔗"
                    android:textSize="12sp"
                    android:layout_marginEnd="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bagikan"
                    android:textColor="@color/neutral_gray"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Edit Interaction (Only for owner) -->
            <LinearLayout
                android:id="@+id/layout_social_edit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:background="?android:attr/selectableItemBackground"
                android:padding="6dp"
                android:layout_marginStart="16dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✏️"
                    android:textSize="12sp"
                    android:layout_marginEnd="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Edit"
                    android:textColor="@color/neutral_gray"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Delete Interaction (Only for owner) -->
            <LinearLayout
                android:id="@+id/layout_social_delete"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:background="?android:attr/selectableItemBackground"
                android:padding="6dp"
                android:layout_marginStart="16dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🗑️"
                    android:textSize="12sp"
                    android:layout_marginEnd="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hapus"
                    android:textColor="#E53935"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
