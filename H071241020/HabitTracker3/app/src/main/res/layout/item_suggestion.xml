<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="6dp"
    android:clickable="true"
    android:focusable="true"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp"
    app:strokeWidth="1.5dp"
    app:strokeColor="@color/card_stroke_light"
    app:cardBackgroundColor="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Emoji Avatar Indicator View -->
        <TextView
            android:id="@+id/text_suggestion_emoji"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_badge_rounded"
            android:backgroundTint="@color/neutral_light_gray"
            android:text="💡"
            android:textStyle="bold"
            android:textSize="22sp"
            android:gravity="center"
            android:layout_marginEnd="12dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Category Badge (Kesehatan, Karir, Mental) -->
            <TextView
                android:id="@+id/text_suggestion_category"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kesehatan"
                android:textColor="?attr/colorPrimary"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:background="@drawable/bg_badge_rounded"
                android:backgroundTint="@color/color_container"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:layout_marginBottom="4dp"/>

            <!-- Habit Title -->
            <TextView
                android:id="@+id/text_suggestion_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Minum Air Putih 2L Sehari"
                android:textColor="@color/on_color_container"
                android:textStyle="bold"
                android:textSize="14sp"/>

            <!-- Habit Description -->
            <TextView
                android:id="@+id/text_suggestion_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Meningkatkan energi tubuh, hidrasi, dan metabolisme harian."
                android:textColor="@color/neutral_gray"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Tambah Pill Button -->
        <TextView
            android:id="@+id/btn_add_suggestion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tambah"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="?attr/colorPrimary"
            android:background="@drawable/bg_badge_rounded"
            android:backgroundTint="@color/neutral_light_gray"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp"
            android:layout_marginStart="8dp" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
