<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/windowBackground"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Screen Header -->
        <TextView
            android:id="@+id/text_profile_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Profil &amp; Penghargaan"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/text_profile_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Lacak tingkat konsistensi dan bagikan prestasimu"
            android:textColor="@color/neutral_gray"
            android:textSize="14sp"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/text_profile_title"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- Bento Card 1: User Info -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_user_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeWidth="1.5dp"
            app:strokeColor="@color/card_stroke_light"
            app:cardBackgroundColor="?attr/colorSurface"
            app:layout_constraintTop_toBottomOf="@id/text_profile_subtitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <!-- Circular Avatar -->
                <FrameLayout
                    android:id="@+id/avatar_container"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:background="@drawable/bg_badge_rounded"
                    android:backgroundTint="@color/color_container"
                    android:layout_marginEnd="16dp"
                    android:clickable="true"
                    android:focusable="true">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_avatar_photo"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        app:cardCornerRadius="32dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp"
                        android:visibility="gone">
                        <ImageView
                            android:id="@+id/image_avatar"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/text_avatar_emoji"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="👤"
                        android:textSize="32sp"
                        android:layout_gravity="center"/>
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/text_user_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pejuang Disiplin"
                        android:textColor="@color/on_color_container"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/text_user_bio"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="&quot;Konsistensi mengalahkan bakat!&quot;"
                        android:textColor="@color/neutral_gray"
                        android:textSize="13sp"
                        android:textStyle="italic"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <!-- Edit Button -->
                <TextView
                    android:id="@+id/btn_edit_profile"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✏️"
                    android:textSize="20sp"
                    android:padding="8dp"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Stats Overview Row inside Bento Grid -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_brief_stats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeWidth="1.5dp"
            app:strokeColor="@color/card_stroke_light"
            app:cardBackgroundColor="?attr/colorSurface"
            app:layout_constraintTop_toBottomOf="@id/card_user_info"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/text_total_created_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="?attr/colorPrimary"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total Target Dibuat"
                        android:textColor="@color/neutral_gray"
                        android:textSize="11sp"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="32dp"
                    android:background="@color/card_stroke_light" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/text_total_checkins_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="?attr/colorPrimary"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total Check-In Sesi"
                        android:textColor="@color/neutral_gray"
                        android:textSize="11sp"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Achievements Title Divider -->
        <TextView
            android:id="@+id/text_badges_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PENCAPAIAN (BADGES)"
            android:textColor="?attr/colorPrimary"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/card_brief_stats"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- Bento Grid Row 2: Badges (Grayscale/Color depending on achievement) -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_badges"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:nestedScrollingEnabled="false"
            app:layout_constraintTop_toBottomOf="@id/text_badges_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Top 3 Habits Section Title -->
        <TextView
            android:id="@+id/text_top_habits_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PRESTASI TERBAIK (TOP 3 HABIT)"
            android:textColor="?attr/colorPrimary"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/recycler_badges"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- Top 3 Habit Cards -->
        <LinearLayout
            android:id="@+id/layout_top_habits_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/text_top_habits_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Dynamic or local bindings of Top 3 rows -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_top_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/card_stroke_light"
                app:cardBackgroundColor="?attr/colorSurface"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_badge_rounded"
                        android:backgroundTint="@color/color_container"
                        android:text="🥇"
                        android:textColor="?attr/colorPrimary"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:gravity="center"
                        android:layout_marginEnd="12dp"/>

                    <TextView
                        android:id="@+id/text_top_1_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@color/on_color_container"
                        android:textStyle="bold"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/text_top_1_streak"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="?attr/colorPrimary"
                        android:textStyle="bold"
                        android:textSize="14sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_top_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/card_stroke_light"
                app:cardBackgroundColor="?attr/colorSurface"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_badge_rounded"
                        android:backgroundTint="@color/color_container"
                        android:text="🥈"
                        android:textColor="?attr/colorPrimary"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:gravity="center"
                        android:layout_marginEnd="12dp"/>

                    <TextView
                        android:id="@+id/text_top_2_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@color/on_color_container"
                        android:textStyle="bold"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/text_top_2_streak"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="?attr/colorPrimary"
                        android:textStyle="bold"
                        android:textSize="14sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_top_3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/card_stroke_light"
                app:cardBackgroundColor="?attr/colorSurface"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_badge_rounded"
                        android:backgroundTint="@color/color_container"
                        android:text="🥉"
                        android:textColor="?attr/colorPrimary"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:gravity="center"
                        android:layout_marginEnd="12dp"/>

                    <TextView
                        android:id="@+id/text_top_3_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@color/on_color_container"
                        android:textStyle="bold"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/text_top_3_streak"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="?attr/colorPrimary"
                        android:textStyle="bold"
                        android:textSize="14sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Bottom Empty State for Top Habits -->
            <TextView
                android:id="@+id/text_top_habits_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Belum ada sesi check-in yang tercatat. Selesaikan habit harianmu untuk mengumpulkan pencapaian!"
                android:textColor="@color/neutral_gray"
                android:textSize="13sp"
                android:gravity="center"
                android:padding="16dp"
                android:visibility="visible" />
        </LinearLayout>

        <!-- User Posts Section Title -->
        <TextView
            android:id="@+id/text_user_posts_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AKTIVITAS SAYA (KIRIMAN KOMUNITAS)"
            android:textColor="?attr/colorPrimary"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/layout_top_habits_container"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- User Custom Posts List -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_user_activities"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:nestedScrollingEnabled="false"
            app:layout_constraintTop_toBottomOf="@id/text_user_posts_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- User Posts Empty State -->
        <TextView
            android:id="@+id/text_user_posts_empty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Belum ada aktivitas yang dibagikan. Bagikan aktivitas pertamamu di tab Inspirasi!"
            android:textColor="@color/neutral_gray"
            android:textSize="13sp"
            android:gravity="center"
            android:padding="16dp"
            app:layout_constraintTop_toBottomOf="@id/text_user_posts_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:visibility="gone" />

        <!-- Bento Card: Pengaturan (Dark Mode Toggle) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_settings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeWidth="1.5dp"
            app:strokeColor="@color/card_stroke_light"
            app:cardBackgroundColor="?attr/colorSurface"
            app:layout_constraintTop_toBottomOf="@id/recycler_user_activities"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PENGATURAN"
                    android:textColor="?attr/colorPrimary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌙"
                        android:textSize="20sp"
                        android:layout_marginEnd="12dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Mode Gelap"
                        android:textColor="?android:attr/textColorPrimary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_dark_mode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Share Button Card/Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_share_achievements"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="80dp"
            android:text="Bagikan Pencapaian"
            android:minHeight="48dp"
            app:cornerRadius="12dp"
            style="@style/Widget.Material3.Button"
            app:layout_constraintTop_toBottomOf="@id/card_settings"
            app:layout_constraintBottom_toBottomOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
