<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/scroll_view_form"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/windowBackground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Form Heading -->
        <TextView
            android:id="@+id/text_form_heading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/add_habit_title"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <!-- Habit Name Input (TextInputLayout style) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeWidth="1.5dp"
            app:strokeColor="@color/card_stroke_light"
            app:cardBackgroundColor="?attr/colorSurface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NAMA KEBIASAAN"
                    android:textColor="?attr/colorPrimary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    app:boxCornerRadiusTopStart="16dp"
                    app:boxCornerRadiusTopEnd="16dp"
                    app:boxCornerRadiusBottomStart="16dp"
                    app:boxCornerRadiusBottomEnd="16dp"
                    app:boxStrokeColor="?attr/colorPrimary"
                    app:hintEnabled="false"
                    app:startIconDrawable="@android:drawable/ic_menu_edit"
                    app:startIconTint="?attr/colorPrimary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edit_text_habit_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Contoh: Olahraga Pagi, Membaca Buku..."
                        android:textColor="?android:attr/textColorPrimary"
                        android:textColorHint="@color/neutral_gray"
                        android:textSize="16sp"
                        android:inputType="textCapSentences"
                        android:importantForAutofill="no" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Frequency & Weekday Select Bento Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeWidth="1.5dp"
            app:strokeColor="@color/card_stroke_light"
            app:cardBackgroundColor="?attr/colorSurface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PILIH HARI PELAKSANAAN"
                    android:textColor="?attr/colorPrimary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chip_group_days_select"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:singleSelection="false">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/form_chip_senin"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Senin" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/form_chip_selasa"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Selasa" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/form_chip_rabu"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rabu" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/form_chip_kamis"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Kamis" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/form_chip_jumat"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Jumat" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/form_chip_sabtu"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sabtu" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/form_chip_minggu"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Minggu" />
                </com.google.android.material.chip.ChipGroup>

                <!-- Automatic Frequency Indicator -->
                <TextView
                    android:id="@+id/text_frequency_indicator"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Jumlah hari: 0 hari/minggu"
                    android:textColor="@color/neutral_gray"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Dynamic Accordion Toggle for Advanced inputs -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_advanced_accordion_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pengaturan Lanjutan (Sembunyikan) ▾"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="?attr/colorPrimary"
            android:backgroundTint="?android:attr/windowBackground"
            app:elevation="0dp"
            app:cornerRadius="10dp"
            app:strokeWidth="1dp"
            app:strokeColor="?attr/colorPrimary"
            android:layout_marginBottom="16dp"
            style="@style/Widget.Material3.Button.OutlinedButton" />

        <!-- EXPANDABLE CONTENT CARD (The Accordion Drawer) -->
        <LinearLayout
            android:id="@+id/layout_advanced_root"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="visible"
            android:layout_marginBottom="24dp">

            <!-- Time Options -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeWidth="1.5dp"
                app:strokeColor="@color/card_stroke_light"
                app:cardBackgroundColor="?attr/colorSurface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PILIH WAKTU"
                        android:textColor="?attr/colorPrimary"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp"/>

                    <RadioGroup
                        android:id="@+id/radio_group_time_type"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/radio_time_free"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Bebas"
                            android:checked="true"
                            android:layout_marginEnd="16dp" />

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/radio_time_specific"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Waktu Spesifik" />
                    </RadioGroup>

                    <!-- Dropdowns for Hour and Minute (only visible if radio_time_specific is selected) -->
                    <LinearLayout
                        android:id="@+id/layout_specific_time_pickers"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:visibility="gone"
                        android:layout_marginTop="4dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Jam:"
                            android:textColor="@color/neutral_gray"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:layout_marginEnd="8dp" />

                        <Spinner
                            android:id="@+id/spinner_hour"
                            android:layout_width="wrap_content"
                            android:layout_height="48dp"
                            android:minWidth="80dp"
                            android:background="@drawable/bg_badge_rounded"
                            android:backgroundTint="@color/neutral_light_gray"
                            android:gravity="center"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=":"
                            android:textColor="?android:attr/textColorPrimary"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:layout_marginStart="8dp"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Menit:"
                            android:textColor="@color/neutral_gray"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:layout_marginEnd="8dp" />

                        <Spinner
                            android:id="@+id/spinner_minute"
                            android:layout_width="wrap_content"
                            android:layout_height="48dp"
                            android:minWidth="80dp"
                            android:background="@drawable/bg_badge_rounded"
                            android:backgroundTint="@color/neutral_light_gray"
                            android:gravity="center"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp" />

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Priority Level Picker -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeWidth="1.5dp"
                app:strokeColor="@color/card_stroke_light"
                app:cardBackgroundColor="?attr/colorSurface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TINGKAT PRIORITAS"
                        android:textColor="?attr/colorPrimary"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="10dp"/>

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chip_group_priority"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:singleSelection="true">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_prio_urgent"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/priority_urgent" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_prio_high"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/priority_high" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_prio_medium"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/priority_medium" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_prio_low"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/priority_low"
                            android:checked="true" />
                    </com.google.android.material.chip.ChipGroup>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Difficulty Picker -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeWidth="1.5dp"
                app:strokeColor="@color/card_stroke_light"
                app:cardBackgroundColor="?attr/colorSurface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TINGKAT KESULITAN"
                        android:textColor="?attr/colorPrimary"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="10dp"/>

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chip_group_difficulty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:singleSelection="true">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_diff_hard"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/difficulty_hard" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_diff_medium"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/difficulty_medium" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_diff_easy"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/difficulty_easy"
                            android:checked="true" />
                    </com.google.android.material.chip.ChipGroup>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Save and Cancel Actions in Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:gravity="center">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_cancel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/cancel"
                android:textColor="?attr/colorPrimary"
                android:layout_marginEnd="12dp"
                android:minHeight="48dp"
                app:cornerRadius="12dp"
                style="@style/Widget.Material3.Button.TextButton" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/save"
                android:minHeight="48dp"
                app:cornerRadius="12dp"
                style="@style/Widget.Material3.Button" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
