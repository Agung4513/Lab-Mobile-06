<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/scroll_view_post_form"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/windowBackground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Form Heading -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/text_post_form_heading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bagikan Aktivitas"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true" />

            <TextView
                android:id="@+id/btn_close_post_form"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="❌"
                android:textSize="20sp"
                android:padding="8dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:clickable="true"
                android:focusable="true" />
        </RelativeLayout>

        <!-- Category/Tag Selection Bento Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeWidth="1.5dp"
            app:strokeColor="@color/card_stroke_light"
            app:cardBackgroundColor="?attr/colorSurface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PILIH KATEGORI AKTIVITAS"
                    android:textColor="?attr/colorPrimary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chip_group_tag_select"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:singleSelection="true">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_pro"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PRODUKTIVITAS"
                        android:checked="true" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_health"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="KESEHATAN" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_learning"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BELAJAR" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_mental"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MENTAL" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_finance"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="KEUANGAN" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_focus"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="FOKUS" />
                </com.google.android.material.chip.ChipGroup>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Activitiy Title Input Bento Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeWidth="1.5dp"
            app:strokeColor="@color/card_stroke_light"
            app:cardBackgroundColor="?attr/colorSurface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="JUDUL AKTIVITAS"
                        android:textColor="?attr/colorPrimary"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:layout_alignParentStart="true" />

                    <TextView
                        android:id="@+id/text_title_counter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0/30"
                        android:textColor="@color/neutral_gray"
                        android:textSize="11sp"
                        android:layout_alignParentEnd="true" />
                </RelativeLayout>

                <EditText
                    android:id="@+id/edit_text_post_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Contoh: Lari Pagi 5 KM"
                    android:background="@null"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textSize="16sp"
                    android:inputType="textCapSentences"
                    android:maxLength="30"
                    android:importantForAutofill="no" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Caption/Body Input Bento Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeWidth="1.5dp"
            app:strokeColor="@color/card_stroke_light"
            app:cardBackgroundColor="?attr/colorSurface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DESKRIPSI / CAPTION"
                        android:textColor="?attr/colorPrimary"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:layout_alignParentStart="true" />

                    <TextView
                        android:id="@+id/text_body_counter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0/120"
                        android:textColor="@color/neutral_gray"
                        android:textSize="11sp"
                        android:layout_alignParentEnd="true" />
                </RelativeLayout>

                <EditText
                    android:id="@+id/edit_text_post_body"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minLines="3"
                    android:gravity="top"
                    android:hint="Bagikan keseruan atau motivasi dari aktivitasmu agar menginspirasi pejuang disiplin lain!"
                    android:background="@null"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textSize="15sp"
                    android:inputType="textMultiLine|textCapSentences"
                    android:maxLength="120"
                    android:importantForAutofill="no" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- PHOTO CONTAINER BENTO CARD -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_select_post_photo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeWidth="1.5dp"
            app:strokeColor="@color/card_stroke_light"
            app:cardBackgroundColor="?attr/colorSurface"
            android:clickable="true"
            android:focusable="true">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="180dp">

                <!-- Placeholder layout (Visible when no photo is picked) -->
                <LinearLayout
                    android:id="@+id/layout_photo_placeholder"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:visibility="visible">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📷"
                        android:textSize="32sp"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Unggah Foto Kegiatan Anda"
                        android:textColor="?attr/colorPrimary"
                        android:textStyle="bold"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Atau kosongkan untuk menggunakan foto modern acak"
                        android:textColor="@color/neutral_gray"
                        android:textSize="11sp"
                        android:layout_marginTop="4dp"
                        android:gravity="center" />
                </LinearLayout>

                <!-- Photo Preview Layout (Visible when photo is picked) -->
                <FrameLayout
                    android:id="@+id/layout_photo_preview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="gone">

                    <ImageView
                        android:id="@+id/image_post_preview"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop" />

                    <!-- Transparent badge/overlay to change picture -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="#44000000" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🔄"
                            android:textSize="24sp"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ubah Foto Kegiatan"
                            android:textColor="@color/white"
                            android:textStyle="bold"
                            android:textSize="12sp" />
                    </LinearLayout>
                </FrameLayout>
            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- SUBMIT / CREATE POST BUTTON -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_submit_post"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bagikan Sekarang"
            android:minHeight="48dp"
            app:cornerRadius="12dp"
            style="@style/Widget.Material3.Button" />
    </LinearLayout>
</ScrollView>
