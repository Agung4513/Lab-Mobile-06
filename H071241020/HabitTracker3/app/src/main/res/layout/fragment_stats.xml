<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/windowBackground"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Screen Header -->
        <TextView
            android:id="@+id/text_stats_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Statistik Harian"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/text_stats_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pantau perkembangan disiplin hidup sehatmu"
            android:textColor="@color/neutral_gray"
            android:textSize="14sp"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/text_stats_title"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- Bento Grid Row 1 Left: Streak Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_streak"
            android:layout_width="0dp"
            android:layout_height="140dp"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="8dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeWidth="1.5dp"
            app:strokeColor="@color/card_stroke_light"
            app:cardBackgroundColor="?attr/colorSurface"
            app:layout_constraintTop_toBottomOf="@id/text_stats_subtitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/card_progress">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="20dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_star"
                    android:contentDescription="Streak"
                    android:tint="@color/priority_high"/>

                <TextView
                    android:id="@+id/text_streak_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="5 Hari"
                    android:textColor="@color/on_color_container"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Winstreak Aktif"
                    android:textColor="@color/neutral_gray"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Bento Grid Row 1 Right: Completion Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_progress"
            android:layout_width="0dp"
            android:layout_height="140dp"
            android:layout_marginTop="20dp"
            android:layout_marginStart="8dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeWidth="1.5dp"
            app:strokeColor="@color/card_stroke_light"
            app:cardBackgroundColor="?attr/colorSurface"
            app:layout_constraintTop_toBottomOf="@id/text_stats_subtitle"
            app:layout_constraintStart_toEndOf="@id/card_streak"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="20dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_stats"
                    android:contentDescription="Progress"
                    android:tint="@color/priority_low"/>

                <TextView
                    android:id="@+id/text_completion_rate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="75%"
                    android:textColor="@color/on_color_container"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rasio Tuntas (Hari ini)"
                    android:textColor="@color/neutral_gray"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Bento Grid Row 2: Total Active Habits Banner Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_total_habits"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeWidth="1.5dp"
            app:strokeColor="@color/card_stroke_light"
            app:cardBackgroundColor="?attr/colorSurface"
            app:layout_constraintTop_toBottomOf="@id/card_streak">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="20dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Target Kebiasaan"
                        android:textColor="@color/neutral_gray"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/text_total_habits_desc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Kamu mengaktifkan 4 target disiplin"
                        android:textColor="@color/on_color_container"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/text_total_habits_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="4"
                    android:textColor="?attr/colorPrimary"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:layout_marginStart="16dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Bento Grid Row 2.5: Cumulative Checked-in Sessions (Persistent Progress) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_total_sessions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeWidth="1.5dp"
            app:strokeColor="@color/card_stroke_light"
            app:cardBackgroundColor="?attr/colorSurface"
            app:layout_constraintTop_toBottomOf="@id/card_total_habits">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="20dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total Sesi Disiplin"
                        android:textColor="@color/neutral_gray"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/text_total_sessions_desc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total pencapaian seluruh target (kumulatif)"
                        android:textColor="@color/on_color_container"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/text_total_sessions_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="?attr/colorPrimary"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:layout_marginStart="16dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Bento Grid Row 3: Detail Progress & Tips Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_tips"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeWidth="1.5dp"
            app:strokeColor="@color/card_stroke_light"
            app:cardBackgroundColor="?attr/colorSurface"
            app:layout_constraintTop_toBottomOf="@id/card_total_sessions"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginBottom="80dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Catatan Evaluasi"
                    android:textColor="@color/on_color_container"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/text_tips_body"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="..."
                    android:textColor="@color/neutral_gray"
                    android:textSize="14sp"
                    android:layout_marginTop="8dp"
                    android:lineSpacingMultiplier="1.2" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
